---
import { siteNav } from '../data/home';
---

<header class="site-header">
	<div class="site-header-inner">
		<a class="brand" href={`${import.meta.env.BASE_URL}`} aria-label="回到听懂CS首页">
			<span class="brand-logo-frame" aria-hidden="true">
				<img class="brand-logo" src={`${import.meta.env.BASE_URL}images/avatar.png`} alt="" />
			</span>
			<span class="brand-text">
				<strong>听懂CS</strong>
				<small>从真实比赛里听懂英语</small>
			</span>
		</a>
		<nav class="site-nav" aria-label="首页导航">
			{siteNav.map((item) => <a href={item.href}>{item.label}</a>)}
		</nav>
	</div>
</header>

<script>
	const header = document.querySelector('.site-header');

	const syncHeaderState = () => {
		header?.classList.toggle('is-scrolled', window.scrollY > 12);
	};

	syncHeaderState();
	window.addEventListener('scroll', syncHeaderState, { passive: true });
</script>
