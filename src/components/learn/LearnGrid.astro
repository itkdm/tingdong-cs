---
import type { LearnCardItem } from '../../data/learn';

interface Props {
	items: LearnCardItem[];
}

const { items } = Astro.props;
---

<section class="learn-grid" aria-label="学习内容列表">
	{
		items.map((item, index) => (
			<a class="learn-card" href={`/learn/${item.slug}/`} aria-label={`进入 ${item.title}`}>
				<div class="learn-card-cover">
					<span class="learn-card-index" aria-label={`第 ${index + 1} 期`}>{String(index + 1).padStart(2, '0')}</span>
					<img src={item.cover.src} width={item.cover.width} height={item.cover.height} alt={item.title} loading="lazy" />
				</div>
				<div class="learn-card-body">
					<h2>{item.title}</h2>
					<p class="learn-card-date">{item.date}</p>
				</div>
			</a>
		))
	}
</section>
