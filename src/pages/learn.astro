---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import LearnGrid from '../components/learn/LearnGrid.astro';
import { getLearnCardItems } from '../data/learn';
import '../styles/shell.css';
import '../styles/learn.css';

const items = await getLearnCardItems();
---

<Layout
	title="学习内容 | 听懂CS"
	description="这里按期整理真实 CS2 / CSGO 比赛片段里的英文解说、赛后采访表达、同步字幕、学习笔记和记忆图，帮助你从语境里学习电竞英语。"
	canonicalPath="/learn/"
	image="/images/hero-bg.png"
>
	<div class="page-shell">
		<SiteHeader />
		<main class="page-main">
			<div class="learn-page">
				<LearnGrid items={items} />
			</div>
		</main>
		<SiteFooter />
	</div>
</Layout>
